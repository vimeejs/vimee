{
  "name": "@vimee/plugin-codemirror",
  "version": "0.2.0",
  "description": "Attach vim editing to a CodeMirror 6 editor instance",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "vim",
    "codemirror",
    "editor",
    "plugin",
    "framework-agnostic"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vimeejs/vimee.git",
    "directory": "packages/plugin-codemirror"
  },
  "peerDependencies": {
    "@vimee/core": ">=0.1.0 <1.0.0",
    "@codemirror/view": "^6.0.0",
    "@codemirror/state": "^6.0.0"
  },
  "devDependencies": {
    "@vimee/core": "workspace:*",
    "@codemirror/view": "6.41.1",
    "@codemirror/state": "6.6.0",
    "happy-dom": "20.8.4"
  }
}
