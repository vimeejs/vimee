{
  "name": "@vimee/plugin-textarea",
  "version": "0.0.0",
  "description": "Attach vim editing to any HTML textarea element",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": ["vim", "textarea", "editor", "plugin", "framework-agnostic"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/konojunya/vimee.git",
    "directory": "packages/plugin-textarea"
  },
  "peerDependencies": {
    "@vimee/core": "workspace:*"
  },
  "devDependencies": {
    "@vimee/core": "workspace:*",
    "happy-dom": "^18.0.1"
  }
}
