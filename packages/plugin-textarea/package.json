{
  "name": "@vimee/plugin-textarea",
  "version": "0.1.2",
  "description": "Attach vim editing to any HTML textarea element",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "vim",
    "textarea",
    "editor",
    "plugin",
    "framework-agnostic"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vimeejs/vimee.git",
    "directory": "packages/plugin-textarea"
  },
  "peerDependencies": {
    "@vimee/core": "^0.2.0"
  },
  "devDependencies": {
    "@vimee/core": "workspace:*",
    "happy-dom": "20.8.4"
  }
}
