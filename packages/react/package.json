{
  "name": "@vimee/react",
  "version": "0.2.0",
  "description": "React hooks for the vimee headless vim engine",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "vim",
    "react",
    "hooks",
    "editor",
    "headless"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vimeejs/vimee.git",
    "directory": "packages/react"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "@vimee/core": ">=0.1.0",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "happy-dom": "^18.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@vimee/core": "workspace:*"
  }
}
