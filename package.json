{
  "name": "vimee",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "bun run --filter '*' build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "oxlint packages/*/src",
    "fmt": "oxfmt --write packages/*/src"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  },
  "packageManager": "bun"
}
