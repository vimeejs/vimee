{
  "name": "vimee",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*", "playground"],
  "scripts": {
    "build": "turbo run build --filter='@vimee/*'",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "bunx oxlint packages/*/src",
    "fmt": "bunx oxfmt --write packages/*/src",
    "changeset": "changeset",
    "changeset:gen": "bash scripts/gen-changeset.sh",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@typescript/native-preview": "^7.0.0-dev.20260321.1",
    "@vitest/coverage-v8": "^4.1.0",
    "tsup": "^8.0.0",
    "turbo": "^2.8.20",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  },
  "packageManager": "bun@1.2.17"
}
