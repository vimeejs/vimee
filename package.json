{
  "name": "vimee",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*", "debug", "e2e"],
  "scripts": {
    "build": "turbo run build --filter='@vimee/*'",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "bunx oxlint packages/*/src",
    "fmt": "bunx oxfmt --write packages/*/src",
    "benchmark": "vitest bench --config vitest.bench.config.ts",
    "changeset": "changeset",
    "changeset:gen": "bash scripts/gen-changeset.sh",
    "release": "changeset publish",
    "e2e": "cd e2e && npx playwright test",
    "debug": "bun run --cwd debug dev"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.6.0",
    "@changesets/cli": "2.30.0",
    "@codspeed/vitest-plugin": "5.2.0",
    "@typescript/native-preview": "7.0.0-dev.20260322.1",
    "@vitest/coverage-v8": "4.1.5",
    "tsup": "8.5.1",
    "turbo": "2.8.20",
    "typescript": "5.9.3",
    "vitest": "4.1.5"
  },
  "packageManager": "bun@1.2.17"
}
